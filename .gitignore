.claude/
# NOTE: .planning/ is tracked locally (audit trail, decision history) but
# blocked from `git push` by .git/hooks/pre-push. Keeps planning work
# private without losing git versioning.

# Regression figures (can be regenerated, large file count)
output/regressions/**/*.png

# Bayesian traces (large NetCDF files, transfer via SCP)
output/bayesian_fits/*.nc
output/*.nc

# Parameter sweep outputs (can be large, regenerable)
output/parameter_sweeps/

# Raw participant data (sensitive — not for public distribution)
data/rlwm_trauma_PARTICIPANT_SESSION_*.csv
data/backup_*.csv
data/participant_id_mapping.json
data/sync_log.txt

# Parsed intermediates (contain raw survey responses + demographics)
output/parsed_demographics.csv
output/parsed_survey*.csv
output/parsed_task_trials.csv
output/demographics_complete.csv
output/participant_info.csv

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Build / packaging
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
nul
*.stackdump

# Quarto manuscript build artifacts
manuscript/_output/
manuscript/_cache/
manuscript/.jupyter_cache/
manuscript/outputs/
manuscript/paper_files/
manuscript/*.aux
manuscript/*.log
manuscript/*.out
manuscript/*.toc
manuscript/*.synctex.gz
manuscript/*.bbl
manuscript/*.blg

# Cluster logs (ephemeral SLURM output)
cluster/logs/

# MLE checkpoints (intermediate fitting state, regenerable)
output/mle/*_checkpoint.csv

# Temporary parameter sweep outputs
output/_tmp_param_sweep*/

# Legacy outputs at repo root (moved to output/mle/)
output/wmrl_m3_*.csv
output/wmrl_m3_*.json
output/wmrl_m5_*.csv
output/wmrl_m5_*.json

# Old milestone outputs (archived)
output/v1/

# Quarto build cache
manuscript/.jupyter_cache/

# Backup files
*.bak

# Personal / external documents (not part of the codebase)
Burrows_J_GDPA_Thesis.*

# Pre-v5 cold-start stash (untracked outputs moved aside before fresh pipeline run)
_stash_pre_v5_cold_start_*/

# Phase 23.1 GPU smoke validation artifacts (throwaway)
output/bayesian/23.1_smoke/

# ============================================================================
# Phase 31 — CCDS-aligned layout (new; co-exists with legacy patterns until
# Waves B/C complete physical moves. Wave E (plan 31-05) removes legacy rows.)
# ============================================================================

# Raw participant data — sensitive, NEVER tracked
data/raw/rlwm_trauma_PARTICIPANT_SESSION_*.csv
data/raw/backup_*.csv
data/raw/participant_id_mapping.json
!data/raw/.gitkeep

# Interim (parsed/collated) — sensitive PII, gitignored
data/interim/parsed_demographics.csv
data/interim/parsed_survey*.csv
data/interim/parsed_task_trials.csv
data/interim/collated_participant_data.csv
data/interim/demographics_complete.csv
data/interim/participant_info.csv
!data/interim/.gitkeep

# Processed — analysis-ready CSVs, TRACKED (except temp dev artifacts)
!data/processed/.gitkeep

# Models — large binary posteriors gitignored; small CSVs tracked
models/bayesian/*.nc
models/bayesian/**/*.nc
models/bayesian/23.1_smoke/
models/mle/*_checkpoint.csv
!models/bayesian/.gitkeep
!models/mle/.gitkeep
!models/ppc/.gitkeep
!models/recovery/.gitkeep
!models/parameter_exploration/.gitkeep

# Reports — tracked for reviewer convenience
!reports/figures/.gitkeep
!reports/tables/.gitkeep

# Logs — always gitignored (dev + SLURM job logs merged here in Wave E)
logs/*
!logs/.gitkeep

