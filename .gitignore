.claude/
# NOTE: .planning/ is tracked locally (audit trail, decision history) but
# blocked from `git push` by .git/hooks/pre-push. Keeps planning work
# private without losing git versioning.

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Build / packaging
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
nul
*.stackdump

# Quarto manuscript build artifacts
manuscript/_output/
manuscript/_cache/
manuscript/.jupyter_cache/
manuscript/outputs/
manuscript/paper_files/
manuscript/*.aux
manuscript/*.log
manuscript/*.out
manuscript/*.toc
manuscript/*.synctex.gz
manuscript/*.bbl
manuscript/*.blg

# Backup files
*.bak

# Personal / external documents (not part of the codebase)
Burrows_J_GDPA_Thesis.*

# Pre-v5 cold-start stash (untracked outputs moved aside before fresh pipeline run)
_stash_pre_v5_cold_start_*/

# ============================================================================
# Phase 31 — CCDS-aligned layout (authoritative; legacy output/ and figures/
# patterns removed in plan 31-05 after physical moves completed in 31-02/03.)
# ============================================================================

# Raw participant data — sensitive, NEVER tracked (wildcard form: any new
# raw artifact is gitignored by default; only .gitkeep is preserved).
data/raw/*
!data/raw/.gitkeep

# Interim (parsed/collated) — sensitive PII, gitignored under the same
# wildcard pattern.
data/interim/*
!data/interim/.gitkeep

# Processed — analysis-ready, EXPLICITLY tracked. CSVs and JSONs ship with
# the repo for OSF deposit + cluster cold-start (see docs/CODEBOOK.md).
# (No ignore pattern needed; listed here for intent visibility.)
!data/processed/.gitkeep
!data/processed/*.csv
!data/processed/*.json

# Models — large binary posteriors gitignored; small CSVs tracked
models/bayesian/*.nc
models/bayesian/**/*.nc
models/bayesian/23.1_smoke/
models/mle/*_checkpoint.csv
!models/bayesian/.gitkeep
!models/mle/.gitkeep
!models/ppc/.gitkeep
!models/recovery/.gitkeep
!models/parameter_exploration/.gitkeep

# Reports — tracked for reviewer convenience
!reports/figures/.gitkeep
!reports/tables/.gitkeep

# Logs — always gitignored (dev + SLURM job logs merged here in Wave E)
logs/*
!logs/.gitkeep

