#!/bin/bash
# Pre-push hook: block commits touching .planning/ from being pushed.
#
# .planning/ is tracked locally (decision history, plans, state) but is
# project-internal — it must not land on the public remote.
# Override for emergencies: git push --no-verify

ZERO="0000000000000000000000000000000000000000"
PROTECTED_RE="^\.planning/"

while read -r local_ref local_sha remote_ref remote_sha; do
    # Ref deletion — nothing to inspect
    [ "$local_sha" = "$ZERO" ] && continue

    # New branch on remote: commits reachable from local that aren't on any existing remote
    if [ "$remote_sha" = "$ZERO" ]; then
        range=$(git rev-list "$local_sha" --not --remotes 2>/dev/null)
    else
        range=$(git rev-list "${remote_sha}..${local_sha}" 2>/dev/null)
    fi

    for sha in $range; do
        if git show --name-only --format= "$sha" | grep -qE "$PROTECTED_RE"; then
            echo ""
            echo "[pre-push] BLOCKED: commit touches .planning/"
            echo ""
            echo "  Commit: $(git log -1 --format='%h %s' "$sha")"
            echo "  Files:"
            git show --name-only --format= "$sha" | grep -E "$PROTECTED_RE" | sed 's/^/    /'
            echo ""
            echo "  .planning/ is local-only per project policy."
            echo "  Keep plans/decisions/state out of the remote."
            echo ""
            echo "  To fix:"
            echo "    - Interactive rebase to drop or split the commit"
            echo "    - git restore --source=<pre-planning-sha> -- .planning/  (to revert tracked changes)"
            echo "    - git push --no-verify  (emergency override only)"
            echo ""
            exit 1
        fi
    done
done

exit 0
